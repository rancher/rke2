#!/usr/bin/env bash
set -ex

cd $(dirname $0)/..

source ./scripts/version.sh

if [ -z "$SKIP_BUILD_IMAGE_RUNTIME" ]; then
    ./scripts/build-image-runtime
fi

BUILD_DIR=${BUILD_DIR:-build}

awk '{print $1}' << EOF > $BUILD_DIR/images-core.txt
    ${REGISTRY}/${REPO}/${PROG}-runtime:${DOCKERIZED_VERSION}
EOF

# use PULL_CMD=echo to print out the images without pulling them
PULL_CMD="${PULL_CMD:-echo}"
# When packaging images.txt, we use docker as rke2-runtime only exists locally
PULL_CMD_CORE="${PULL_CMD_CORE:-docker image pull --quiet}"

INGRESS_NGINX_HARDENED_TAG=v1.14.5-hardened2
INGRESS_NGINX_PRIME_TAG=v1.15.1-prime8
INGRESS_NGINX_IMAGES="
    ${REGISTRY}/rancher/kube-webhook-certgen:${INGRESS_NGINX_HARDENED_TAG}
    ${REGISTRY}/rancher/nginx-ingress-controller:${INGRESS_NGINX_HARDENED_TAG}"

if [ "${REGISTRY}" != "docker.io" ]; then
    INGRESS_NGINX_IMAGES="${INGRESS_NGINX_IMAGES}
    ${REGISTRY}/rancher/kube-webhook-certgen:${INGRESS_NGINX_PRIME_TAG}
    ${REGISTRY}/rancher/nginx-ingress-controller:${INGRESS_NGINX_PRIME_TAG}"

    if [ "${GOARCH}" != "arm64" ]; then
        xargs -n1 -t $PULL_CMD_CORE << EOF >> $BUILD_DIR/images-ovirt.txt
        ${REGISTRY}/rancher/mirrored-ovirt-csi-driver:4.15.0
        ${REGISTRY}/rancher/mirrored-sig-storage-csi-attacher:v4.10.0
        ${REGISTRY}/rancher/mirrored-sig-storage-csi-node-driver-registrar:v2.15.0
        ${REGISTRY}/rancher/mirrored-sig-storage-csi-provisioner:v6.0.0
        ${REGISTRY}/rancher/mirrored-sig-storage-csi-resizer:v1.14.0
        ${REGISTRY}/rancher/mirrored-sig-storage-livenessprobe:v2.17.0
EOF
    fi
fi

xargs -n1 -t $PULL_CMD_CORE << EOF >> $BUILD_DIR/images-core.txt
    ${REGISTRY}/rancher/hardened-kubernetes:${KUBERNETES_IMAGE_TAG}
    ${REGISTRY}/rancher/hardened-coredns:v1.14.6-build20260722
    ${REGISTRY}/rancher/hardened-cluster-autoscaler:v1.10.3-build20260717
    ${REGISTRY}/rancher/hardened-dns-node-cache:1.26.8-build20260722
    ${REGISTRY}/rancher/hardened-etcd:${ETCD_VERSION}-build20260722
    ${REGISTRY}/rancher/hardened-k8s-metrics-server:v0.9.0-build20260722
    ${REGISTRY}/rancher/hardened-addon-resizer:1.8.23-build20260717
    ${REGISTRY}/rancher/klipper-helm:${KLIPPERHELM_VERSION}
    ${REGISTRY}/rancher/klipper-lb:${KLIPPERLB_VERSION}
    ${REGISTRY}/rancher/mirrored-pause:${PAUSE_VERSION}
    ${REGISTRY}/rancher/rke2-cloud-provider:${CCM_VERSION}
    ${REGISTRY}/rancher/rke2-security-responder:v0.1.4
    ${REGISTRY}/rancher/hardened-snapshot-controller:v8.6.0-build20260722
    ${REGISTRY}/rancher/hardened-traefik:v3.7.8-build20260717
EOF

xargs -n1 -t $PULL_CMD << EOF > $BUILD_DIR/images-ingress-nginx.txt
    ${INGRESS_NGINX_IMAGES}
EOF

xargs -n1 -t $PULL_CMD_CORE << EOF > $BUILD_DIR/images-canal.txt
    ${REGISTRY}/rancher/hardened-calico:v3.32.1-build20260722
    ${REGISTRY}/rancher/hardened-flannel:v0.28.8-build20260722
EOF

xargs -n1 -t $PULL_CMD << EOF > $BUILD_DIR/images-cilium.txt
    ${REGISTRY}/rancher/mirrored-cilium-certgen:v0.4.6
    ${REGISTRY}/rancher/mirrored-cilium-cilium:v1.19.6
    ${REGISTRY}/rancher/mirrored-cilium-cilium-envoy:v1.36.9-1782267392-edeb3f2af56c37c407efa1f63f0b32f595399bbc
    ${REGISTRY}/rancher/mirrored-cilium-clustermesh-apiserver:v1.19.6
    ${REGISTRY}/rancher/mirrored-cilium-hubble-relay:v1.19.6
    ${REGISTRY}/rancher/mirrored-cilium-hubble-ui:v0.13.5
    ${REGISTRY}/rancher/mirrored-cilium-hubble-ui-backend:v0.13.5
    ${REGISTRY}/rancher/mirrored-cilium-operator-aws:v1.19.6
    ${REGISTRY}/rancher/mirrored-cilium-operator-azure:v1.19.6
    ${REGISTRY}/rancher/mirrored-cilium-operator-generic:v1.19.6
    ${REGISTRY}/rancher/hardened-cni-plugins:v1.9.1-build20260717
EOF

xargs -n1 -t $PULL_CMD << EOF > $BUILD_DIR/images-calico.txt
    ${REGISTRY}/rancher/mirrored-calico-operator:v1.42.3
    ${REGISTRY}/rancher/mirrored-calico-ctl:v3.32.1
    ${REGISTRY}/rancher/mirrored-calico-kube-controllers:v3.32.1
    ${REGISTRY}/rancher/mirrored-calico-typha:v3.32.1
    ${REGISTRY}/rancher/mirrored-calico-node:v3.32.1
    ${REGISTRY}/rancher/mirrored-calico-pod2daemon-flexvol:v3.32.1
    ${REGISTRY}/rancher/mirrored-calico-cni:v3.32.1
    ${REGISTRY}/rancher/mirrored-calico-apiserver:v3.32.1
    ${REGISTRY}/rancher/mirrored-calico-csi:v3.32.1
    ${REGISTRY}/rancher/mirrored-calico-node-driver-registrar:v3.32.1
    ${REGISTRY}/rancher/mirrored-calico-envoy-gateway:v3.32.1
    ${REGISTRY}/rancher/mirrored-calico-envoy-proxy:v3.32.1
    ${REGISTRY}/rancher/mirrored-calico-envoy-ratelimit:v3.32.1
    ${REGISTRY}/rancher/mirrored-calico-goldmane:v3.32.1
    ${REGISTRY}/rancher/mirrored-calico-whisker:v3.32.1
    ${REGISTRY}/rancher/mirrored-calico-whisker-backend:v3.32.1
EOF

if [ "${GOARCH}" != "arm64" ]; then

    if [ "${REGISTRY}" != "docker.io" ]; then
xargs -n1 -t $PULL_CMD << EOF > $BUILD_DIR/images-vsphere.txt
    ${REGISTRY}/rancher/hardened-cloud-provider-vsphere:v1.36.0-build20260722
    ${REGISTRY}/rancher/hardened-vsphere-csi-driver:v3.7.2-build20260722
    ${REGISTRY}/rancher/hardened-vsphere-csi-syncer:v3.7.2-build20260722
    ${REGISTRY}/rancher/hardened-csi-node-driver-registrar:v2.17.0-build20260722
    ${REGISTRY}/rancher/hardened-csi-resizer:v2.2.1-build20260722
    ${REGISTRY}/rancher/hardened-livenessprobe:v2.19.0-build20260722
    ${REGISTRY}/rancher/hardened-csi-attacher:v4.12.0-build20260722
    ${REGISTRY}/rancher/hardened-csi-provisioner:v6.3.0-build20260722
    ${REGISTRY}/rancher/hardened-csi-snapshotter:v8.6.0-build20260722
EOF
    else
xargs -n1 -t $PULL_CMD << EOF > $BUILD_DIR/images-vsphere.txt
    ${REGISTRY}/rancher/mirrored-cloud-provider-vsphere:v1.36.0
    ${REGISTRY}/rancher/mirrored-cloud-provider-vsphere-csi-release-driver:v3.7.2
    ${REGISTRY}/rancher/mirrored-cloud-provider-vsphere-csi-release-syncer:v3.7.2
    ${REGISTRY}/rancher/mirrored-sig-storage-csi-node-driver-registrar:v2.13.0
    ${REGISTRY}/rancher/mirrored-sig-storage-csi-resizer:v1.12.0
    ${REGISTRY}/rancher/mirrored-sig-storage-livenessprobe:v2.15.0
    ${REGISTRY}/rancher/mirrored-sig-storage-csi-attacher:v4.9.0
    ${REGISTRY}/rancher/mirrored-sig-storage-csi-provisioner:v4.0.1
    ${REGISTRY}/rancher/hardened-csi-snapshotter:v8.6.0-build20260722
EOF
    fi

fi

xargs -n1 -t $PULL_CMD << EOF > $BUILD_DIR/images-multus.txt
    ${REGISTRY}/rancher/hardened-multus-cni:v4.3.0-build20260722
    ${REGISTRY}/rancher/hardened-multus-thick:v4.3.0-build20260722
    ${REGISTRY}/rancher/hardened-multus-dynamic-networks-controller:v0.3.8-build20260722
    ${REGISTRY}/rancher/hardened-cni-plugins:v1.9.1-build20260717
    ${REGISTRY}/rancher/hardened-whereabouts:v0.9.4-build20260721
    ${REGISTRY}/rancher/mirrored-library-busybox:1.36.1
EOF

xargs -n1 -t $PULL_CMD << EOF > $BUILD_DIR/images-harvester.txt
    ${REGISTRY}/rancher/harvester-cloud-provider:v0.2.7
    ${REGISTRY}/rancher/mirrored-kube-vip-kube-vip-iptables:v1.1.2
    ${REGISTRY}/rancher/harvester-csi-driver:v0.2.9
    ${REGISTRY}/rancher/mirrored-longhornio-csi-node-driver-registrar:v2.16.0-20260428
    ${REGISTRY}/rancher/mirrored-longhornio-csi-resizer:v2.1.0-20260428
    ${REGISTRY}/rancher/mirrored-longhornio-csi-provisioner:v5.3.0-20260428
    ${REGISTRY}/rancher/mirrored-longhornio-csi-attacher:v4.11.0-20260428
    ${REGISTRY}/rancher/mirrored-longhornio-csi-snapshotter:v8.5.0-20260428
EOF

xargs -n1 -t $PULL_CMD << EOF > $BUILD_DIR/images-flannel.txt
    ${REGISTRY}/rancher/hardened-flannel:v0.28.8-build20260722
    ${REGISTRY}/rancher/hardened-cni-plugins:v1.9.1-build20260717
EOF

# Continue to provide a legacy airgap archive set with the default CNI images
cat $BUILD_DIR/images-core.txt $BUILD_DIR/images-canal.txt > $BUILD_DIR/images.txt
